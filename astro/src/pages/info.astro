---
import BaseLayout from "~/layouts/BaseLayout.astro";
import InfoPage from "~/page-content/InfoPage";
import { sanityClient } from "~/lib/sanity";
import { faqsQuery } from "~/lib/queries";
import type { FaqsQueryResult } from "~/lib/sanity.types";

const faqs = await sanityClient.fetch<FaqsQueryResult>(faqsQuery);
---
<BaseLayout
    description="Your Guide to The Matlock Raft Event. Discover all the important details about the event."
    title="Event Information - Matlock Raft Event"
>
    <InfoPage client:load faqs={faqs} />
</BaseLayout>
