// Gatsbys required rules
{
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "project": [
            "**/tsconfig.json"
        ]
    },
    "plugins": [
        "react",
        "@typescript-eslint",
        "simple-import-sort"
    ],
    "env": {
        "browser": true,
        "node": true
    },
    "extends": [
        "airbnb",
        "airbnb-typescript",
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:react/recommended"
    ],
    "settings": {
        "react": {
            "version": "detect"
        },
        "import/resolver": {
            "typescript": {
                "alwaysTryTypes": true
            }
        }
    },
    "rules": {
        // 2 space indents
        "indent": "off",
        "react/jsx-indent": "off",
        "@typescript-eslint/indent": [
            "warn",
            2
        ],
        // Only use double quotes
        "@typescript-eslint/quotes": [
            "warn",
            "double"
        ],
        // No trailing commas
        "@typescript-eslint/comma-dangle": [
            "warn",
            "never"
        ],
        // No unused variables
        "@typescript-eslint/no-unused-vars": [
            "warn",
            {
                "vars": "all",
                "args": "none"
            }
        ],
        // Leading and trailing space inside { }
        "object-curly-spacing": [
            "warn",
            "always"
        ],
        // Prefer destructuring in objects, not in arrays
        "prefer-destructuring": [
            "warn",
            {
                "object": true,
                "array": false
            }
        ],
        // Don't enforce linebreaks inside parentheses of function parameters or arguments
        "function-paren-newline": "off",
        // Line length unrestricted (long Tailwind class strings are normal)
        "max-len": "off",
        // Don't enforce linebreaks to be placed before/after
        "operator-linebreak": "off",
        // Don't enforce linebreaks in arrow functions
        "implicit-arrow-linebreak": "off",
        // Don't enforce linebreaks after opening & before closing braces
        "object-curly-newline": "off",
        // Enforces no parens in arrow function parameters where they can be omitted.
        "arrow-parens": [
            "warn",
            "as-needed"
        ],
        // Alphabetize props
        "react/jsx-sort-props": [
            "warn"
        ],
        // Sanity uses _ prefixes for blocks, allow these
        "no-underscore-dangle": "off",
        // Don't enforce wrapping multine JSX in ( )
        "react/jsx-wrap-multilines": "off",
        // Don't expect a different spacing for props
        "react/jsx-indent-props": "off",
        // Only used for testing but allow alerts nonetheless
        "no-alert": "off",
        // Always prefer arrow functions
        "react/function-component-definition": [
            "warn",
            {
                "namedComponents": "arrow-function",
                "unnamedComponents": "arrow-function"
            }
        ],
        // No need to expect import React from "react" in every file
        "react/react-in-jsx-scope": "off",
        // Allow prop spreading
        "react/jsx-props-no-spreading": "off",
        // Don't warn if imports should be reordered as we use simple-import-sort instead
        "import/order": "off",
        // Warn, don't error if trailing whitespace
        "no-trailing-spaces": [
            "warn"
        ],
        "@typescript-eslint/semi": [
            "warn"
        ],
        // Allow optional props without a default value
        "react/require-default-props": "off",
        // Resolver gets confused between root (Gatsby) and astro/ packages.
        // Turn off until the root Gatsby project is removed.
        "import/no-extraneous-dependencies": "off",
        // Organise imports
        "simple-import-sort/imports": "warn",
        "simple-import-sort/exports": "warn",
        // Path aliases resolve without explicit extensions
        "import/extensions": "off",
        // Don't insist that every import path is resolvable from the linter's CWD
        "import/no-unresolved": "off"
    },
    "overrides": [
        // override "simple-import-sort" config
        {
            "files": [
                "*.js",
                "*.jsx",
                "*.ts",
                "*.tsx"
            ],
            "rules": {
                "simple-import-sort/imports": [
                    "warn",
                    {
                        "groups": [
                            // Packages `react` related packages come first.
                            [
                                "^react",
                                "^(@[^A-Z][^.])",
                                "^([a-z][^A-Z][^.])"
                            ],
                            // Internal packages.
                            [
                                "^~"
                            ],
                            // Side effect imports.
                            [
                                "^\\u0000"
                            ],
                            // Parent imports. Put `..` last.
                            [
                                "^\\.\\.(?!/?$)",
                                "^\\.\\./?$"
                            ],
                            // Other relative imports. Put same-folder imports and `.` last.
                            [
                                "^\\./(?=.*/)(?!/?$)",
                                "^\\.(?!/?$)",
                                "^\\./?$"
                            ],
                            // Style imports.
                            [
                                "^.+\\.?(css)$"
                            ]
                        ]
                    }
                ]
            }
        }
    ]
}
