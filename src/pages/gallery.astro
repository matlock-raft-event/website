---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GalleryPage from "~/page-content/gallery-page";
import { sanityClient } from "~/lib/sanity";
import { galleryQuery } from "~/lib/queries";
import type { GalleryQueryResult } from "~/lib/sanity.types";

const galleryImages = await sanityClient.fetch<GalleryQueryResult>(galleryQuery);
---
<BaseLayout
    description="Browse through the memorable moments captured at our past events. See the excitement, fun, and joy from the event."
    title="Gallery - Matlock Raft Event"
>
    <GalleryPage client:load galleryImages={galleryImages} />
</BaseLayout>
