---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SponsorsPage from "~/page-content/SponsorsPage";
import { sanityClient } from "~/lib/sanity";
import { sponsorsQuery } from "~/lib/queries";
import type { SponsorsQueryResult } from "~/lib/sanity.types";

const sponsors = await sanityClient.fetch<SponsorsQueryResult>(sponsorsQuery);
---
<BaseLayout
    description="Explore the valued sponsors who have contributed to the success of the event. The Matlock Raft Event would not be possible without their support."
    title="Our Event Sponsors - Matlock Raft Event"
>
    <SponsorsPage client:load sponsors={sponsors} />
</BaseLayout>
