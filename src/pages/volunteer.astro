---
import BaseLayout from "~/layouts/BaseLayout.astro";
import VolunteerPage from "~/page-content/volunteer-page";
import { sanityClient } from "~/lib/sanity";
import { volunteerPageQuery } from "~/lib/queries";
import type { VolunteerPageQueryResult } from "~/lib/sanity.types";

const volunteerPage = await sanityClient.fetch<VolunteerPageQueryResult>(volunteerPageQuery);
---
<BaseLayout
    description="Volunteer at the Matlock Raft Event. Learn how to help as a safety marshall or donation collector."
    title="Volunteer - Matlock Raft Event"
>
    <VolunteerPage client:load volunteerPage={volunteerPage} />
</BaseLayout>
